# Copy this file to .env.local and fill in values for local development.
# Never commit .env.local — it is git-ignored.

# Application
APP_NAME=cooked
IMAGE_TAG=latest
PORT=3000

# Container registry (used by `make package`)
REGISTRY=ghcr.io/rdlucas2

# SonarQube (used by `make sonar-scan`)
# Generate a token at http://localhost:9000 after running `make sonar-start`
SONAR_TOKEN=

# Edamam Recipe Search API (free tier: 10 req/min, 10,000 req/month)
# Register at https://developer.edamam.com → create a "Recipe Search v2" application
# Add both values as Vercel Project Settings → Environment Variables for production
EDAMAM_APP_ID=your_app_id_here
EDAMAM_APP_KEY=your_app_key_here
